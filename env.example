GITHUB_TOKEN=your_token
GITHUB_USERNAME=your_username

# Contact form — restart dev server after changing
REACT_APP_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key
# Optional: only if you use your own hCaptcha on Web3Forms paid plan.
# Free plan: leave unset; app uses Web3Forms' built-in hCaptcha site key.
# REACT_APP_HCAPTCHA_SITE_KEY=
